  RowBox[{"\[Delta]k", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"Detmet", "[", "]"}], "]"}], "*", 
      RowBox[{"(", 
